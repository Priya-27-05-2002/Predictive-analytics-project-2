plt.figure(figsize=(6,4))
sns.countplot(data=df_clean, x='Target_Pass', hue='Target_Pass', palette="Set2", legend=False)
plt.title("Class Distribution (0 = Fail, 1 = Pass)")
plt.savefig("results/class_distribution.png")
